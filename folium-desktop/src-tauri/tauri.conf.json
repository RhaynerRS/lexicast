{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Folium",
  "version": "0.1.0",
  "identifier": "com.folium.desktop",
  "build": {
    "beforeDevCommand": "npm run build --prefix ../folium-ui",
    "beforeBuildCommand": "npm run build --prefix ../folium-ui",
    "frontendDist": "../../folium-ui/out"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Folium",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
