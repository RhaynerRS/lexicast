<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="680"
             x:Class="LexicastUi.Views.ProgressView">

    <StackPanel Margin="40,32" Spacing="24" MaxWidth="640" HorizontalAlignment="Center">

        <StackPanel Spacing="6">
            <TextBlock Text="EM ANDAMENTO" Classes="Eyebrow" />
            <TextBlock Text="Traduzindo seu EPUB" FontSize="28" FontWeight="Bold" />
            <TextBlock x:Name="FileNameText" Opacity="0.7" TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Border Classes="Card" Padding="28">
            <StackPanel Spacing="22">

                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="StatusText" Text="Status: enviando..." FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" x:Name="ProgressPercentText" Text="0%"
                                   Foreground="{DynamicResource AccentTextBrush}" FontWeight="Bold" />
                    </Grid>
                    <ProgressBar x:Name="JobProgressBar" Minimum="0" Maximum="100" Value="0" Height="10" CornerRadius="5" />
                </StackPanel>

                <Border x:Name="WarningBanner" Classes="Banner Warning" IsVisible="False">
                    <TextBlock x:Name="WarningText" Foreground="#F2A93C" TextWrapping="Wrap" />
                </Border>

                <Border x:Name="ErrorBanner" Classes="Banner Error" IsVisible="False">
                    <TextBlock x:Name="ErrorText" Foreground="#E5484D" TextWrapping="Wrap" />
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button x:Name="DownloadButton"
                            Content="Baixar tradução"
                            Classes="accent"
                            IsEnabled="False"
                            Click="DownloadButton_Click" />
                    <Button x:Name="CancelButton"
                            Content="Cancelar tradução"
                            Classes="Secondary"
                            Click="CancelButton_Click" />
                    <Button x:Name="NewTranslationButton"
                            Content="Nova tradução"
                            Classes="Secondary"
                            Click="NewTranslationButton_Click" />
                    <ProgressBar x:Name="DownloadProgressBar" Width="22" Height="22" IsIndeterminate="True" IsVisible="False" />
                </StackPanel>

            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
