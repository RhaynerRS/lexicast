<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="240"
        x:Class="LexicastUi.Views.SettingsWindow"
        Title="Configurações"
        Width="420" Height="240"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">

    <StackPanel Margin="24" Spacing="18">
        <StackPanel Spacing="4">
            <TextBlock Text="CONFIGURAÇÕES" Classes="Eyebrow" />
            <TextBlock Text="Conexão com a API" FontSize="20" FontWeight="Bold" />
            <TextBlock Text="Salvo no ambiente do usuário — não precisa ser preenchido a cada sessão."
                       Opacity="0.7" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Spacing="8">
            <TextBlock Text="URL da API" Classes="FieldLabel" />
            <TextBox x:Name="ApiUrlBox" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
            <Button Content="Cancelar" Classes="Secondary" Click="CancelButton_Click" />
            <Button Content="Salvar" Classes="accent" Click="SaveButton_Click" />
        </StackPanel>
    </StackPanel>
</Window>
