<Window
    x:Class="LexicastUi.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Lexicast EPUB Translator"
    Width="980"
    Height="740"
    MinWidth="760"
    MinHeight="560"
    d:DesignHeight="740"
    d:DesignWidth="980"
    Background="{DynamicResource AppBackgroundBrush}"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Classes="HeroHeader">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" Classes="LogoMark">
                    <TextBlock Text="L" FontWeight="Bold" FontSize="20" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="Lexicast" FontSize="20" FontWeight="Bold" Foreground="White" />
                    <TextBlock Text="Tradutor de EPUB com IA" FontSize="12" Foreground="#D8D3FF" />
                </StackPanel>
                <Button Grid.Column="2" Classes="HeaderButton" Content="Configurações"
                        VerticalAlignment="Center" Click="SettingsButton_Click" />
            </Grid>
        </Border>
        <ContentControl Grid.Row="1" x:Name="RootContent" />
    </Grid>
</Window>
