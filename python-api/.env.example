# URL do endpoint OpenAI-compatible do Ollama (precisa terminar em /v1)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Modelo usado via Ollama (default: qwen3:0.6b-q4_K_M)
OLLAMA_MODEL=qwen3:0.6b-q4_K_M

# Chave dummy exigida pela lib LLM; o Ollama nao valida (default: ollama)
OLLAMA_API_KEY=ollama

# Encoding tiktoken usado para estimar tokens ao agrupar segmentos (default: cl100k_base)
TOKEN_ENCODING=cl100k_base

# Diretorio onde os epubs enviados/traduzidos sao armazenados (default: ./data)
STORAGE_DIR=./data

# Numero de jobs de traducao que podem rodar em paralelo (default: 4)
JOB_WORKERS=4
